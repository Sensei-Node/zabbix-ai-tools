# ===========================================================================
# Zabbix GenAI Insights — Environment Configuration
# ===========================================================================

# ---------------------------------------------------------------------------
# LLM Provider Configuration
# ---------------------------------------------------------------------------
# Supported providers: gemini | openai | deepseek | ollama
LLM_PROVIDER=gemini

# Model name (provider-specific). Examples:
#   gemini   → gemini-pro, gemini-1.5-pro
#   openai   → gpt-4o, gpt-4o-mini, gpt-3.5-turbo
#   deepseek → deepseek-chat, deepseek-reasoner
#   ollama   → llama3, mistral, codellama
LLM_MODEL=gemini-pro

# API Keys — only the key matching your chosen provider is required
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Ollama (local models — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Legacy alias (still supported for backward compatibility)
GENAI_MODEL=gemini-pro

# ---------------------------------------------------------------------------
# Custom Prompt (optional — overrides the default structured prompt)
# ---------------------------------------------------------------------------
GENAI_PROMPT=

# ---------------------------------------------------------------------------
# Output Configuration (Docker Version Only)
# ---------------------------------------------------------------------------
# FILE = save .txt files only
# DB   = save to SQLite only
# BOTH = save to both (default)
GENAI_OUTPUT_TYPE=BOTH

# ---------------------------------------------------------------------------
# Graylog / SIEM Enrichment
# ---------------------------------------------------------------------------
GRAYLOG_ENABLED=false
GRAYLOG_URL=https://graylog.example.com
GRAYLOG_TOKEN=your_graylog_api_token
GRAYLOG_SEARCH_MINUTES=30
GRAYLOG_SEARCH_LIMIT=100
GRAYLOG_VERIFY_SSL=false

# ---------------------------------------------------------------------------
# MCP (Zabbix MCP Server Integration)
# ---------------------------------------------------------------------------
MCP_ENABLED=false
ZABBIX_MCP_URL=http://zabbix-mcp:8000/sse

# ---------------------------------------------------------------------------
# Retention Policy (Docker Version Only)
# ---------------------------------------------------------------------------
# Maximum number of insights to keep (0 = unlimited)
GENAI_MAX_OUTPUTS=100
