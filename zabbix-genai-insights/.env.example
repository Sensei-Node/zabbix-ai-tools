# Google GenAI Configuration
GOOGLE_API_KEY=your_google_api_key_here
GENAI_MODEL=gemini-pro
GENAI_PROMPT="Você é um especialista de infraestrutura blockchain. Analise os valores e tagging recebidos como entrada de dados de um monitoramento Zabbix e devolva insights técnicos e acionáveis sobre o evento."

# Output Configuration (Docker Version Only)
GENAI_OUTPUT_TYPE=BOTH

# Graylog Enrichment
GRAYLOG_ENABLED=false
GRAYLOG_URL=https://graylog.example.com
GRAYLOG_TOKEN=your_graylog_api_token
GRAYLOG_SEARCH_MINUTES=30

# Retention Policy (Docker Version Only)
GENAI_MAX_OUTPUTS=100
