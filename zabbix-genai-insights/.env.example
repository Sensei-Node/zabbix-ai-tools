# AI Provider Selection (gemini or openai)
AI_PROVIDER=gemini

# Shared Configuration
DEFAULT_PROMPT="Você é um especialista de infraestrutura blockchain. Analise os valores e tagging recebidos como entrada de dados de um monitoramento Zabbix e devolva insights técnicos e acionáveis sobre o evento."

# Google GenAI Configuration
GOOGLE_API_KEY=your_google_api_key_here
GENAI_MODEL=gemini-pro

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Output Configuration (Docker Version Only)
GENAI_OUTPUT_TYPE=BOTH

# Graylog Enrichment
GRAYLOG_ENABLED=false
GRAYLOG_URL=https://graylog.example.com
GRAYLOG_TOKEN=your_graylog_api_token
GRAYLOG_SEARCH_MINUTES=30

# MCP (Zabbix MCP Server Integration)
MCP_ENABLED=false
ZABBIX_MCP_URL=http://zabbix-mcp:8000/sse

# Retention Policy (Docker Version Only)
GENAI_MAX_OUTPUTS=100
