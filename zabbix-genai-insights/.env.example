# AI Provider Selection (gemini or openai)
AI_PROVIDER=gemini
AI_API_KEY=your_unified_api_key_here
AI_MODEL=model_name_here

# Shared Configuration
DEFAULT_PROMPT="You are a Senior SRE Specialist focused on Blockchain Infrastructure (Node Operator).

ANALYSIS GUIDELINES:
1. Review the 'Perennial Context' section to understand the role of this host and its recurring technical history.

2. Analyze the Zabbix event data and correlate it with SIEM and MCP logs (if available).

3. Be technical, direct, and avoid redundancies (such as references to 'Notify' or 'STRAPI').

RESPONSE STRUCTURE:
- [TECHNICAL ANALYSIS]: Immediate diagnosis of the problem.

- [PERENNIAL CONTEXT]: How this event connects to the host's known history.

- [RECOMMENDED ACTIONS]: Immediate technical steps for mitigation/resolution.

- [MEMORY LOG]: A short sentence summarizing the new learning about this host's behavior for perennial archiving."

# Google GenAI Configuration
GOOGLE_API_KEY=your_google_api_key_here
GENAI_MODEL=gemini-pro

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# DeepSeek Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Output Configuration (Docker Version Only)
OUTPUT_TYPE=BOTH

# Graylog Enrichment
GRAYLOG_ENABLED=false
GRAYLOG_URL=https://graylog.example.com
GRAYLOG_TOKEN=your_graylog_api_token
GRAYLOG_SEARCH_MINUTES=30

# Perennial Memory (Mem0ai - Docker Only)
MEMORY_ENABLED=false
MEM0_DIR=/app/data/mem0

# Retention Policy (Docker Version Only)
MAX_OUTPUTS=100
